# Backend — development image
# Mounts source as a volume so code changes reload instantly via flask --debug

FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Source is mounted at runtime via docker-compose volume
# COPY is only needed when building standalone
COPY . .

ENV FLASK_ENV=development \
    FLASK_DEBUG=1 \
    PYTHONUNBUFFERED=1

EXPOSE 5000

CMD ["python", "run.py"]
